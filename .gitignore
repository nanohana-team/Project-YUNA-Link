# ============================================================
# Project YUNA Link — .gitignore
# ============================================================

# ---- ビルド成果物 ----
build/
out/
*.dll
*.lib
*.exp
*.pdb
*.obj
*.ilk
*.iobj
*.ipdb
x64/

# ---- Visual Studio ----
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.filters   # 自動生成なので除外（手動管理する場合はコメントアウト）

# ---- CMake（将来対応時） ----
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
*.whl

# ---- モデルファイル（大容量） ----
models/*.pt
models/*.onnx
models/*.bin
models/*.safetensors
models/*.pth

# ---- ログ ----
logs/*.log
logs/*.txt

# ---- 設定ローカル上書き ----
config/local_*.yaml
config/local_*.json
config/*.local.yaml

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---- その他 ----
*.bak
*.tmp
*.swp
*.pt